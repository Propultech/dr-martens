{%- doc -%}
  Renders block content for all blocks that extend the group block.

  @param {string} children - The DOM content of the group block.
  @param {object} settings - The settings of the group block.
  @param {string} shopify_attributes - String with Shopify attributes for the editor.
  @param {string} [class] - Custom classes for the group block.
  @param {string} [style] - Custom inline styles for the group block.
  @param {string} [group_id] - Unique block id used for CSS scoping.
  @param {string} [custom_css] - Custom CSS declarations for this specific group block.

  @example
  {% render 'group', children: children, settings: block.settings, shopify_attributes: block.shopify_attributes %}
{%- enddoc -%}

<div
  class="
    group-block
    {% if group_id != blank %}group-block--{{ group_id }}{% endif %}
    {% if settings.visibility == 'desktop' %}hidden--mobile{% elsif settings.visibility == 'mobile' %}hidden--desktop{% endif %}
    group-block--height-{{ settings.height }}
    group-block--width-{{ settings.width }}
    group-block--width-mobile-{{ settings.width_mobile | default: settings.width }}
    border-style
    spacing-style
    size-style
    {% if settings.inherit_color_scheme == false %} color-{{ settings.color_scheme }}{% endif %}
    {{ class }}
  "
  style="
    {% render 'border-override', settings: settings %}
    {% render 'spacing-style', settings: settings %}
    {% render 'size-style', settings: settings %}
    {{ style }}
  "
  {{ shopify_attributes }}
  data-testid="group-block"
>
  {%- if settings.link != blank -%}
    <a
      href="{{ settings.link }}"
      class="group-block__link"
      {% if settings.open_in_new_tab %}
        target="_blank" rel="noopener"
      {% endif %}
    ></a>
  {%- endif -%}

  <div class="group-block__media-wrapper">
    {% render 'background-media',
      background_media: settings.background_media,
      background_video: settings.video,
      background_video_position: settings.video_position,
      background_image: settings.background_image,
      background_image_position: settings.background_image_position,
      background_image_visibility: settings.background_image_visibility,
      background_image_horizontal_position: settings.background_image_horizontal_position,
      background_image_vertical_alignment: settings.background_image_vertical_alignment,
      background_image_max_height_desktop: settings.background_image_max_height_desktop,
      background_image_max_height_mobile: settings.background_image_max_height_mobile,
      placeholder: settings.placeholder
    %}
    {% if settings.toggle_overlay %}
      {% render 'overlay', settings: settings, layer: '0' %}
    {% endif %}
  </div>

  <div
    class="
      group-block-content
      {% if request.design_mode %}group-block-content--design-mode{% endif %}
      layout-panel-flex
      layout-panel-flex--{{ settings.content_direction | default: 'column' }}
      {% if settings.vertical_on_mobile and settings.enable_slider != true %} mobile-column{% endif %}
      {% if settings.enable_slider %}group-block-content--slider-{{ settings.slider_on | default: 'both' }}{% endif %}
    "
    style="
      {% render 'layout-panel-style', settings: settings %}
      {% if settings.enable_slider and settings.slider_scrollbar_color != blank %}--slider-scrollbar-color: {{ settings.slider_scrollbar_color }};{% endif %}
    "
  >
    {{- children -}}
  </div>
</div>

{%- if custom_css != blank and group_id != blank -%}
  <style>
    /* Mode 1: declarations for the group container itself */
    .group-block--{{ group_id }} {
      {{ custom_css }}
    }

    /* Mode 2: selector rules scoped to this group (e.g. h3 { ... }) */
    @scope (.group-block--{{ group_id }}) {
      {{ custom_css }}
    }
  </style>
{%- endif -%}

{% stylesheet %}
  /* ── Slider / scroll horizontal ────────────────────────────── */

  /* Shared slider styles */
  .group-block-content.group-block-content--slider-both,
  .group-block-content.group-block-content--slider-desktop {
    flex-flow: row nowrap;
    overflow-x: scroll;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: var(--slider-scrollbar-color, currentColor) transparent;
    -webkit-overflow-scrolling: touch;
  }

  @media screen and (min-width: 750px) {
    .group-block-content.group-block-content--slider-both,
    .group-block-content.group-block-content--slider-desktop {
      cursor: grab;
    }

    .group-block-content.group-block-content--slider-both.is-dragging,
    .group-block-content.group-block-content--slider-desktop.is-dragging {
      cursor: grabbing;
      user-select: none;
    }
  }

  /* Remove scrollbar arrow buttons (WebKit) */
  .group-block-content[class*="group-block-content--slider-"]::-webkit-scrollbar-button {
    display: none;
    width: 0;
    height: 0;
  }

  .group-block-content.group-block-content--slider-both > *,
  .group-block-content.group-block-content--slider-desktop > * {
    scroll-snap-align: start;
    flex-shrink: 0;
  }

  /* Mobile-only slider */
  @media screen and (max-width: 749px) {
    .group-block-content.group-block-content--slider-mobile {
      flex-flow: row nowrap;
      overflow-x: scroll;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      scrollbar-width: thin;
      scrollbar-color: var(--slider-scrollbar-color, currentColor) transparent;
      -webkit-overflow-scrolling: touch;
    }

    .group-block-content.group-block-content--slider-mobile > * {
      scroll-snap-align: start;
      flex-shrink: 0;
    }
  }

  /* Desktop-only slider: disable on mobile */
  @media screen and (max-width: 749px) {
    .group-block-content.group-block-content--slider-desktop {
      flex-flow: row wrap;
      overflow-x: visible;
      scroll-snap-type: none;
    }

    .group-block-content.group-block-content--slider-desktop > * {
      scroll-snap-align: none;
      flex-shrink: 1;
    }
  }

  /* ─────────────────────────────────────────────────────────── */

  .group-block__link {
    position: absolute;
    inset: 0;
  }

  .group-block__link ~ :is(.group-block-content, .group-block__media-wrapper) {
    pointer-events: none;

    :is(a, button, input, textarea, select) {
      pointer-events: auto;
    }
  }

  /* Needs the .group-block__link ~ to be specific enough to take effect. */
  .group-block__link ~ .group-block-content--design-mode {
    pointer-events: auto;
  }
{% endstylesheet %}

<script>
  (() => {
    if (window.__groupSliderDesktopDragInitialized) return;
    window.__groupSliderDesktopDragInitialized = true;

    const selector = '.group-block-content.group-block-content--slider-both, .group-block-content.group-block-content--slider-desktop';
    const interactiveSelector = 'a, button, input, textarea, select, label, summary';

    let activeSlider = null;
    let pointerId = null;
    let startX = 0;
    let startScrollLeft = 0;
    let hasMoved = false;

    const isDesktop = () => window.matchMedia('(min-width: 750px)').matches;

    document.addEventListener(
      'pointerdown',
      (event) => {
        if (!isDesktop() || event.button !== 0) return;

        const target = event.target;
        if (!(target instanceof Element)) return;

        const slider = target.closest(selector);
        if (!(slider instanceof HTMLElement)) return;
        if (target.closest(interactiveSelector)) return;

        activeSlider = slider;
        pointerId = event.pointerId;
        startX = event.clientX;
        startScrollLeft = slider.scrollLeft;
        hasMoved = false;

        slider.classList.add('is-dragging');
        slider.setPointerCapture?.(pointerId);
      },
      { passive: true }
    );

    document.addEventListener(
      'pointermove',
      (event) => {
        if (!activeSlider || event.pointerId !== pointerId) return;

        const deltaX = event.clientX - startX;
        if (Math.abs(deltaX) > 4) hasMoved = true;

        activeSlider.scrollLeft = startScrollLeft - deltaX;
      },
      { passive: true }
    );

    const finishDrag = () => {
      if (!activeSlider) return;
      activeSlider.classList.remove('is-dragging');
      activeSlider = null;
      pointerId = null;
    };

    document.addEventListener('pointerup', finishDrag);
    document.addEventListener('pointercancel', finishDrag);

    document.addEventListener(
      'click',
      (event) => {
        if (!hasMoved) return;
        hasMoved = false;
        event.preventDefault();
        event.stopPropagation();
      },
      true
    );
  })();
</script>
