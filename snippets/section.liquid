{%- doc -%}
  Renders a wrapper section

  @param {section} section - The section object
  @param {string} children - The children of the section
{%- enddoc -%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    color-{{ section.settings.color_scheme }}
    {% if section.settings.enable_sticky_section %}section--sticky-enabled{% endif %}
  "
  data-testid="ui-test-section"

  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}

  style="
    {% if section.settings.section_height == 'custom' %}
      --section-min-height: {{ section.settings.section_height_custom }}svh;
    {% elsif section.settings.section_height == 'full-screen' %}
      --section-min-height: 100svh;
    {% elsif section.settings.section_height != '' %}
      --section-min-height: var(--section-height-{{ section.settings.section_height }});
    {% endif %}

    {% if section.settings.section_height != '' %}
     --section-preview-height: 600px;
     {% endif %}

    --sticky-section-offset-desktop: {{ section.settings.sticky_section_offset_desktop | default: 0 }}px;
    --sticky-section-offset-mobile: {{ section.settings.sticky_section_offset_mobile | default: 0 }}px;
  "
>
  <div class="custom-section-background">
    {% render 'background-media',
      background_media: section.settings.background_media,
      background_video: section.settings.video,
      background_video_position: section.settings.video_position,
      background_image: section.settings.background_image,
      background_image_position: section.settings.background_image_position,
      background_image_visibility: section.settings.background_image_visibility,
      background_image_horizontal_position: section.settings.background_image_horizontal_position,
      background_image_vertical_alignment: section.settings.background_image_vertical_alignment,
      background_image_max_height_desktop: section.settings.background_image_max_height_desktop,
      background_image_max_height_mobile: section.settings.background_image_max_height_mobile
    %}
  </div>

  <div
    class="border-style custom-section-content"
    style="{% render 'border-override', settings: section.settings %}"
  >
    {% if section.settings.toggle_overlay %}
      {% render 'overlay', settings: section.settings, layer: '0' %}
    {% endif %}

    <div
      class="
        spacing-style
        layout-panel-flex
        layout-panel-flex--{{ section.settings.content_direction }}
        section-content-wrapper
        {% if section.settings.vertical_on_mobile %} mobile-column{% endif %}
      "
      style="
        {% render 'layout-panel-style', settings: section.settings %}
        {% render 'spacing-style', settings: section.settings %}
      "
      data-testid="section-content"
    >
      {{ children }}
    </div>
  </div>
</div>

{% stylesheet %}
  .section-wrapper {
    --section-height-offset: 0px;
  }

  .section[data-shopify-visual-preview] {
    min-height: var(--section-preview-height);
    padding-top: 0;
  }

  .section[data-shopify-visual-preview] .custom-section-background {
    display: none;
  }

  body:has(> #header-group > .header-section > #header-component[transparent]):not(
      :has(> #header-group > .header-section + .shopify-section)
    )
    > main
    > .section-wrapper:first-child {
    --section-height-offset: var(--header-group-height, 0);
  }

  .custom-section-background {
    grid-column: 1 / -1;
  }

  .custom-section-content {
    z-index: var(--layer-flat);
  }

  .section--sticky-enabled {
    z-index: calc(var(--layer-sticky) - 2);
  }

  .section--sticky-enabled.is-fixed {
    position: fixed;
    z-index: calc(var(--layer-sticky) - 2);
  }

  .shopify-section.section-sticky-host {
    position: relative;
  }
{% endstylesheet %}

<script>
  (() => {
    const STICKY_FUDGE_PX = -1;

    const controller = window.__customSectionStickyController || {
      initialized: false,
      entries: new Map(),
      rafId: null,
    };
    window.__customSectionStickyController = controller;
    if (controller.initialized) return;
    controller.initialized = true;

    const getHeaderOffset = () => {
      const activeHeader = document.querySelector(
        '#header-group .header[data-sticky-state="active"]:not([data-animating])'
      );
      if (activeHeader instanceof HTMLElement) {
        return Math.max(0, activeHeader.getBoundingClientRect().height + STICKY_FUDGE_PX);
      }

      const headerComponent = document.querySelector('#header-group #header-component');
      if (!(headerComponent instanceof HTMLElement)) return 0;

      const stickyMode = headerComponent.getAttribute('sticky');
      if (!stickyMode) return 0;
      if (stickyMode === 'scroll-up' && headerComponent.dataset.stickyState === 'idle') return 0;

      const cssHeight = Number.parseFloat(
        getComputedStyle(document.documentElement).getPropertyValue('--header-group-height')
      );
      if (Number.isFinite(cssHeight)) return cssHeight;

      const headerGroup = document.getElementById('header-group');
      return headerGroup instanceof HTMLElement ? headerGroup.getBoundingClientRect().height : 0;
    };

    const getUserOffset = (sectionEl) => {
      const isMobile = window.matchMedia('(max-width: 749px)').matches;
      const variableName = isMobile ? '--sticky-section-offset-mobile' : '--sticky-section-offset-desktop';
      const raw = getComputedStyle(sectionEl).getPropertyValue(variableName);
      const parsed = Number.parseFloat(raw);
      return Number.isFinite(parsed) ? parsed : 0;
    };

    const unsetFixedState = (entry) => {
      const { host, sectionEl } = entry;
      host.style.paddingTop = '';
      sectionEl.style.top = '';
      sectionEl.style.left = '';
      sectionEl.style.width = '';
      sectionEl.classList.remove('is-fixed');
    };

    const setFixedState = (entry) => {
      const { host, sectionEl } = entry;
      const hostRect = host.getBoundingClientRect();
      host.style.paddingTop = `${sectionEl.offsetHeight}px`;
      sectionEl.style.top = `${getHeaderOffset() + getUserOffset(sectionEl)}px`;
      sectionEl.style.left = `${hostRect.left}px`;
      sectionEl.style.width = `${hostRect.width}px`;
      sectionEl.classList.add('is-fixed');
    };

    const syncStickySections = () => {
      document.querySelectorAll('.section--sticky-enabled').forEach((sectionEl) => {
        if (!(sectionEl instanceof HTMLElement)) return;
        const host = sectionEl.closest('.shopify-section');
        if (!(host instanceof HTMLElement)) return;
        host.classList.add('section-sticky-host');
        controller.entries.set(sectionEl, { sectionEl, host });
      });

      controller.entries.forEach((entry, key) => {
        if (!entry.sectionEl.isConnected || !entry.host.isConnected) {
          unsetFixedState(entry);
          controller.entries.delete(key);
        }
      });
    };

    const updateAll = () => {
      controller.rafId = null;
      syncStickySections();

      controller.entries.forEach((entry) => {
        const top = entry.host.getBoundingClientRect().top;
        const threshold = getHeaderOffset() + getUserOffset(entry.sectionEl);
        if (top <= threshold) {
          setFixedState(entry);
        } else {
          unsetFixedState(entry);
        }
      });
    };

    const scheduleUpdate = () => {
      if (controller.rafId) return;
      controller.rafId = requestAnimationFrame(updateAll);
    };

    window.addEventListener('scroll', scheduleUpdate, { passive: true });
    window.addEventListener('resize', scheduleUpdate, { passive: true });
    window.addEventListener('load', scheduleUpdate);
    document.addEventListener('shopify:section:load', scheduleUpdate);
    document.addEventListener('shopify:section:unload', scheduleUpdate);
    document.addEventListener('shopify:section:reorder', scheduleUpdate);
    document.addEventListener('shopify:section:select', scheduleUpdate);
    document.addEventListener('shopify:section:deselect', scheduleUpdate);

    scheduleUpdate();
  })();
</script>
