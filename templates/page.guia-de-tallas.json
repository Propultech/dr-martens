                },
                "accordion_row_jMdNAy": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "¿Las Dr. Martens vienen en medias tallas?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_HWCca6": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Our shoes and boots are available in whole sizes only. You can use our size chart to find your best fit.<br/><br/><strong>Tip:</strong>If you normally wear a half size in women’s US sizes, we’d recommend sizing down. If you typically wear a half size in men’s US sizes, we’d recommend sizing up.</p>",
                        "width": "100%",
                        "max_width": "none",
                        "alignment": "left",
                        "type_preset": "custom",
                        "font": "var(--font-body--family)",
                        "weight": "",
                        "font_size": "1rem",
                        "font_size_mobile": "",
                        "line_height": "loose",
                        "letter_spacing": "normal",
