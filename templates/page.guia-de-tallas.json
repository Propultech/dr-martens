                  ]
                },
                "accordion_row_xJwPjk": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "¿Dónde puedo encontrar el tamaño de mis DM?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_Xkydpe": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Sizes will be marked inside the tongue of your original Dr. Martens and on the inside the ankle strap of most of our sandal styles. Remember that Made in England Styles will have the UK size listed and not the US size.</p>",
                        "width": "100%",
                        "max_width": "none",
