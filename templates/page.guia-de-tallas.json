                "accordion_row_XRDNBM": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "¿Cuál es la diferencia entre las tallas de calzado para hombres, mujeres y unisex?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_qC6J7n": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Women’s styles will generally say “Women’s” in the name and will have a slimmer and more tapered shape. Men’s and Unisex styles have a more rounded fit and wider footbed shape. <br/><br/><strong>Tip:</strong>Unisex styles can be identified by the size selection on the style's product page. If a size is Unisex, both Men’s and Women's sizing options appear.</p>",
                        "width": "100%",
                        "max_width": "none",
                        "alignment": "left",
                        "type_preset": "custom",
                        "font": "var(--font-body--family)",
                        "weight": "",
                        "font_size": "1rem",
                        "font_size_mobile": "",
                        "line_height": "loose",
