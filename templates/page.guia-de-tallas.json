                },
                "accordion_row_eiGtCT": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "¿Qué pasa si estoy acostumbrado a las tallas europeas?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_r9kHW8": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Most wearers accustomed to the Euro size system will see the number they usually wear or one higher on the box when they get the correct US size. See our size chart above for the conversion from your European size to a US Women or US Men size.</p>",
                        "width": "100%",
                        "max_width": "none",
                        "alignment": "left",
                        "type_preset": "custom",
                        "font": "var(--font-body--family)",
                        "weight": "",
