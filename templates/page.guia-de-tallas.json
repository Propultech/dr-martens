                  ]
                },
                "accordion_row_HfLpYY": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "¿Qué tipo de calcetines debo usar con mis nuevos DM?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_EYYthd": {
                      "type": "text",
                      "settings": {
                        "text": "<p>We recommend you wear a sock that has a bit of cushion and is high enough that it meets the top of the footwear. Our<a href=\"https://www.drmartens.com/us/en/p/AC742001\"><span style=\"text-decoration:underline\">Double Doc sock</span></a>is a lined sock designed with extra cushion in all the right places. Pairing your footwear with these socks and<a href=\"https://www.drmartens.com/us/en/p/AC787000\"><span style=\"text-decoration:underline\">Wonder Balsam</span></a>is a great way to comfortably break in your DMs to suit you perfectly.</p>",
                        "width": "100%",
                        "max_width": "none",
                        "alignment": "left",
                        "type_preset": "custom",
                        "font": "var(--font-body--family)",
