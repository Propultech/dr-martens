{% liquid
  assign description_output = section.settings.description | strip | escape
  assign highlight_output = section.settings.description_highlight | strip | escape
  if highlight_output != blank and description_output contains highlight_output
    assign highlight_markup = '<em>' | append: highlight_output | append: '</em>'
    assign description_output = description_output | replace: highlight_output, highlight_markup
  endif
%}

<div
  class="section section--{{ section.settings.section_width }} spacing-style timeline-collage-hero color-{{ section.settings.color_scheme }}"
  style="
    {% render 'spacing-style', settings: section.settings %}
    --canvas-height-desktop: {{ section.settings.canvas_height_desktop }}px;
    --canvas-height-mobile: {{ section.settings.canvas_height_mobile }}px;
    --title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --title-x-desktop: {{ section.settings.title_offset_x_desktop }}px;
    --title-y-desktop: {{ section.settings.title_offset_y_desktop }}px;
    --title-x-mobile: {{ section.settings.title_offset_x_mobile }}px;
    --title-y-mobile: {{ section.settings.title_offset_y_mobile }}px;
    --desc-size-desktop: {{ section.settings.description_size_desktop }}px;
    --desc-size-mobile: {{ section.settings.description_size_mobile }}px;
    --desc-width-desktop: {{ section.settings.description_max_width_desktop }}px;
    --desc-width-mobile: {{ section.settings.description_max_width_mobile }}px;
    --desc-x-desktop: {{ section.settings.description_offset_x_desktop }}px;
    --desc-y-desktop: {{ section.settings.description_offset_y_desktop }}px;
    --desc-x-mobile: {{ section.settings.description_offset_x_mobile }}px;
    --desc-y-mobile: {{ section.settings.description_offset_y_mobile }}px;
    --left-width-desktop: {{ section.settings.left_image_width_desktop }}px;
    --left-width-mobile: {{ section.settings.left_image_width_mobile }}px;
    --left-x-desktop: {{ section.settings.left_image_offset_x_desktop }}px;
    --left-y-desktop: {{ section.settings.left_image_offset_y_desktop }}px;
    --left-x-mobile: {{ section.settings.left_image_offset_x_mobile }}px;
    --left-y-mobile: {{ section.settings.left_image_offset_y_mobile }}px;
    --left-rotation: {{ section.settings.left_image_rotation }}deg;
    --right-width-desktop: {{ section.settings.right_image_width_desktop }}px;
    --right-width-mobile: {{ section.settings.right_image_width_mobile }}px;
    --right-x-desktop: {{ section.settings.right_image_offset_x_desktop }}px;
    --right-y-desktop: {{ section.settings.right_image_offset_y_desktop }}px;
    --right-x-mobile: {{ section.settings.right_image_offset_x_mobile }}px;
    --right-y-mobile: {{ section.settings.right_image_offset_y_mobile }}px;
    --right-rotation: {{ section.settings.right_image_rotation }}deg;
  "
>
  <div
    class="timeline-collage-hero__canvas"
    {% if section.settings.background_image != blank %}
      style="background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');"
    {% endif %}
  >
    {% if section.settings.left_image != blank %}
      <div class="timeline-collage-hero__float timeline-collage-hero__float--left{% if section.settings.left_image_shadow %} has-shadow{% endif %}">
        <img
          src="{{ section.settings.left_image | image_url: width: 1200 }}"
          alt="{{ section.settings.left_image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.left_image.width }}"
          height="{{ section.settings.left_image.height }}"
        >
      </div>
    {% endif %}

    {% if section.settings.right_image != blank %}
      <div class="timeline-collage-hero__float timeline-collage-hero__float--right{% if section.settings.right_image_shadow %} has-shadow{% endif %}">
        <img
          src="{{ section.settings.right_image | image_url: width: 1200 }}"
          alt="{{ section.settings.right_image.alt | escape }}"
          loading="lazy"
          width="{{ section.settings.right_image.width }}"
          height="{{ section.settings.right_image.height }}"
        >
      </div>
    {% endif %}

    {% if section.settings.title != blank %}
      <div class="timeline-collage-hero__title-wrap">
        <h2 class="timeline-collage-hero__title">
          <span class="timeline-collage-hero__title-text">{{ section.settings.title | escape }}</span>
        </h2>
      </div>
    {% endif %}

    {% if section.settings.description != blank %}
      <div class="timeline-collage-hero__description-wrap">
        <p class="timeline-collage-hero__description">
          <span class="timeline-collage-hero__description-text">{{ description_output }}</span>
        </p>
      </div>
    {% endif %}

  </div>

  <div class="timeline-collage-hero__body page-width">
    {% for block in section.blocks %}
      {% if block.type == 'overlay_text' %}
        <div class="timeline-collage-hero__body-text">
          {% render 'text', block: block, class: 'timeline-collage-hero__body-text-content', width: '100%' %}
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .timeline-collage-hero {
    position: relative;
    z-index: 0;
    overflow: visible;
  }

  .timeline-collage-hero__canvas {
    position: relative;
    min-height: var(--canvas-height-mobile);
    background-color: #dddddd;
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    overflow: visible;
  }

  .timeline-collage-hero__title-wrap {
    position: absolute;
    left: 50%;
    top: 25%;
    transform: translate(calc(-50% + var(--title-x-mobile)), calc(-50% + var(--title-y-mobile)));
    z-index: 2;
    max-width: 92%;
    text-align: center;
  }

  .timeline-collage-hero__title {
    margin: 0;
    line-height: 1;
    font-size: var(--title-size-mobile);
    font-weight: 400;
    text-transform: uppercase;
  }

  .timeline-collage-hero__title-text {
    display: inline;
    background: #000;
    color: #fff;
    padding: 0.08em 0.24em 0.12em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .timeline-collage-hero__description-wrap {
    position: absolute;
    left: 50%;
    top: 54%;
    transform: translate(calc(-50% + var(--desc-x-mobile)), calc(-50% + var(--desc-y-mobile)));
    z-index: 2;
    width: min(92%, var(--desc-width-mobile));
    text-align: center;
  }

  .timeline-collage-hero__description {
    margin: 0;
    line-height: 1.2;
    font-size: var(--desc-size-mobile);
    font-weight: 400;
    text-transform: uppercase;
  }

  .timeline-collage-hero__description-text {
    display: inline;
    white-space: normal;
    background: #000;
    color: #fff;
    padding: 0 0.2em;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  .timeline-collage-hero__description em {
    color: #ffe100;
    font-style: normal;
  }

  .timeline-collage-hero__float {
    position: absolute;
    z-index: 1;
    pointer-events: none;
  }

  .timeline-collage-hero__float img {
    display: block;
    width: 100%;
    height: auto;
  }

  .timeline-collage-hero__float.has-shadow img {
    box-shadow: 0 16px 34px rgb(0 0 0 / 0.3);
  }

  .timeline-collage-hero__float--left {
    left: 0;
    top: 54%;
    width: var(--left-width-mobile);
    transform: translate(var(--left-x-mobile), calc(-50% + var(--left-y-mobile))) rotate(var(--left-rotation));
  }

  .timeline-collage-hero__float--right {
    right: 0;
    top: 30%;
    width: var(--right-width-mobile);
    transform: translate(var(--right-x-mobile), calc(-50% + var(--right-y-mobile))) rotate(var(--right-rotation));
  }

  .timeline-collage-hero__body {
    margin-top: 20px;
    position: relative;
    z-index: 3;
    text-align: center;
  }

  .timeline-collage-hero__body-text .text-block {
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .timeline-collage-hero__canvas {
      min-height: var(--canvas-height-desktop);
    }

    .timeline-collage-hero__title-wrap {
      transform: translate(calc(-50% + var(--title-x-desktop)), calc(-50% + var(--title-y-desktop)));
    }

    .timeline-collage-hero__title {
      font-size: var(--title-size-desktop);
    }

    .timeline-collage-hero__description-wrap {
      width: min(92%, var(--desc-width-desktop));
      transform: translate(calc(-50% + var(--desc-x-desktop)), calc(-50% + var(--desc-y-desktop)));
    }

    .timeline-collage-hero__description {
      font-size: var(--desc-size-desktop);
    }

    .timeline-collage-hero__float--left {
      width: var(--left-width-desktop);
      transform: translate(var(--left-x-desktop), calc(-50% + var(--left-y-desktop))) rotate(var(--left-rotation));
    }

    .timeline-collage-hero__float--right {
      width: var(--right-width-desktop);
      transform: translate(var(--right-x-desktop), calc(-50% + var(--right-y-desktop))) rotate(var(--right-rotation));
    }

  }
{% endstylesheet %}

{% schema %}
{
