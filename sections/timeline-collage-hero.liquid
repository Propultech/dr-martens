      "unit": "px",
      "default": 1305
    },
    {
      "type": "range",
      "id": "description_max_width_mobile",
      "label": "Ancho descripción (móvil)",
      "min": 220,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 540
    },
    {
      "type": "range",
      "id": "description_offset_x_desktop",
