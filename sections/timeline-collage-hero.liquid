    {
      "type": "range",
      "id": "title_offset_x_desktop",
      "label": "Título X (escritorio)",
      "min": -250,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_offset_y_desktop",
      "label": "Título Y (escritorio)",
      "min": -250,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_offset_x_mobile",
      "label": "Título X (móvil)",
      "min": -250,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "title_offset_y_mobile",
      "label": "Título Y (móvil)",
      "min": -250,
      "max": 250,
      "step": 5,
      "unit": "px",
      "default": 0
